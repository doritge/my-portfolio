---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog — emergence">
  <div class="blog">
    <h1>Blog</h1>
    <p>Coming soon.</p>
  </div>
</BaseLayout>

<style>
  .blog {
    max-width: 640px;
    margin: 4rem auto 2rem;
    padding: 0 2rem;
  }

  h1 {
    font-size: 1.4rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    margin-bottom: 1.5rem;
  }

  p {
    font-size: 1rem;
    line-height: 1.75;
    color: #444;
  }
</style>
