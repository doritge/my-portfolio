---
interface Props {
  title: string;
  year: number;
  slug: string;
  coverImage: string;
}

const { title, slug, coverImage } = Astro.props;
---

<a href={`/projects/${slug}`} class="card">
  <div class="thumb">
    <img src={coverImage} alt={title} loading="lazy" />
  </div>
  <div class="meta">
    <span class="title">{title}</span>
  </div>
</a>

<style>
  .card {
    display: block;
    text-decoration: none;
    color: #111;
    -webkit-touch-callout: none;
    user-select: none;
  }

  .card:hover .thumb img {
    opacity: 0.85;
  }

  @media (hover: none) {
    .card:active {
      transform: scale(0.97);
      transition: transform 0.1s ease;
    }
  }

  .thumb {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f5f5f5;
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.2s ease;
  }

  .meta {
    padding: 0.75rem 0 0;
    text-align: center;
  }

  .title {
    display: block;
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #111;
  }
</style>
