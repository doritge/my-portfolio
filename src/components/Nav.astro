---
const pathname = Astro.url.pathname;
const isArt = pathname === '/';
const isBlog = pathname.startsWith('/blog');
const isAbout = pathname === '/about';
---

<nav>
  <a href="/" class="brand">
    <span class="site-name">EMERGENCE</span>
    <span class="site-sub">by Dorit Geifman</span>
  </a>
  <ul>
    <li><a href="/" class={isArt ? 'active' : ''}>SERIES</a></li>
    <li><a href="/blog" class={isBlog ? 'active' : ''}>BLOG</a></li>
    <li><a href="/about" class={isAbout ? 'active' : ''}>ABOUT</a></li>
  </ul>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: white;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2.5rem;
    border-bottom: 1px solid #e8e8e8;
  }

  .brand {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-decoration: none;
    color: #111;
  }

  .site-name {
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1.1;
  }

  .site-sub {
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #666;
  }

  ul {
    list-style: none;
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  ul a {
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: #aaa;
    transition: color 0.15s ease;
  }

  ul a:hover {
    color: #111;
  }

  ul a.active {
    color: #444;
  }
</style>
